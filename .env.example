# MCP template defaults
MCP_LOG_LEVEL=info

# TeamDynamix Web API configuration
TEAMDYNAMIX_BASE_URL=https://your-organization.teamdynamix.com/TDWebApi
TEAMDYNAMIX_AUTH_MODE=standard

# Standard auth
TEAMDYNAMIX_USERNAME=your.username@example.com
TEAMDYNAMIX_PASSWORD=replace-me

# Admin auth
TEAMDYNAMIX_BEID=replace-me
TEAMDYNAMIX_WEB_SERVICES_KEY=replace-me

# Optional defaults — set to a positive integer if you want a tenant-wide default app ID
# TEAMDYNAMIX_DEFAULT_TICKET_APP_ID=12345
# TEAMDYNAMIX_DEFAULT_ASSET_APP_ID=23456
# TEAMDYNAMIX_DEFAULT_KB_APP_ID=34567
TEAMDYNAMIX_TIMEOUT_MS=30000
TEAMDYNAMIX_MAX_RETRIES=2
TEAMDYNAMIX_ENABLE_WRITE_TOOLS=false
TEAMDYNAMIX_ENABLE_ADMIN_TOOLS=false