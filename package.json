{
  "name": "@selfagency/teamdynamix-mcp",
  "version": "0.1.1",
  "private": false,
  "description": "A production-ready TypeScript MCP server for TeamDynamix",
  "keywords": [
    "mcp",
    "model context protocol",
    "server",
    "tdx",
    "teamdynamix",
    "typescript"
  ],
  "homepage": "https://github.com/selfagency/teamdynamix-mcp",
  "bugs": {
    "url": "https://github.com/selfagency/teamdynamix-mcp/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Daniel Sieradski",
    "email": "daniel@self.agency"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/selfagency/teamdynamix-mcp.git"
  },
  "bin": "dist/index.js",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "postbuild": "node scripts/write-dist-package.js",
    "dev": "tsx watch src/index.ts",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "prepare": "husky",
    "release": "zx scripts/release.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tablemark": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ora": "^9.3.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vite": "8.0.9",
    "vitepress": "^1.6.4",
    "vitest": "4.1.4",
    "zx": "^8.8.5"
  },
  "lint-staged": {
    "*.{ts,mts,cts,js,mjs,cjs}": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern --write"
    ],
    "*.{json,yaml,yml,md}": [
      "oxfmt --no-error-on-unmatched-pattern --write"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13"
    }
  },
  "mcpName": "io.github.selfagency/teamdynamix-mcp"
}
